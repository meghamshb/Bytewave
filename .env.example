# ByteWave — environment variables
# Copy to .env: cp .env.example .env
# Never commit .env or real secrets.

# REQUIRED — Anthropic API key (Claude)
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# RECOMMENDED for production — JWT secret
# If unset, ephemeral secret is used; tokens invalid after restart
JWT_SECRET=

# Optional — admin key for /api/admin/prerender-clips
ADMIN_KEY=

# Optional — CORS origins (comma-separated)
# CORS_ORIGINS=https://yourdomain.com,http://localhost:5173

# Optional — PostHog analytics (VITE_ prefix for frontend)
VITE_POSTHOG_KEY=
